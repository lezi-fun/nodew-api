generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum APIKeyStatus {
  ACTIVE
  REVOKED
}

enum ChannelStatus {
  ACTIVE
  DISABLED
}

enum RedemptionStatus {
  ACTIVE
  REDEEMED
  REVOKED
}

model User {
  id                          String       @id @default(cuid())
  email                       String       @unique
  username                    String       @unique
  passwordHash                String
  displayName                 String?
  emailVerifiedAt             DateTime?
  passwordResetTokenHash      String?
  passwordResetTokenExpiresAt DateTime?
  passwordResetRequestedAt    DateTime?
  accessToken                 String?      @unique
  settings                    Json?
  role                        UserRole     @default(USER)
  status                      UserStatus   @default(ACTIVE)
  groupId                     String?
  quotaRemaining              BigInt       @default(0)
  quotaUsed                   BigInt       @default(0)
  lastLoginAt                 DateTime?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
  group                       Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  apiKeys                     APIKey[]
  usageLogs                   UsageLog[]
  createdApiKeys              APIKey[]     @relation("APIKeyCreator")
  createdRedemptions          Redemption[] @relation("RedemptionCreator")
  redeemedRedemptions         Redemption[] @relation("RedeemedByUser")

  @@index([role])
  @@index([status])
  @@index([groupId])
}

model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Redemption {
  id               String           @id @default(cuid())
  codeHash         String           @unique
  codePrefix       String
  quotaAmount      BigInt
  status           RedemptionStatus @default(ACTIVE)
  expiresAt        DateTime?
  redeemedByUserId String?
  redeemedAt       DateTime?
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  redeemedByUser   User?            @relation("RedeemedByUser", fields: [redeemedByUserId], references: [id], onDelete: SetNull)
  createdBy        User             @relation("RedemptionCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdById])
  @@index([redeemedByUserId])
}

model APIKey {
  id             String       @id @default(cuid())
  userId         String
  createdById    String?
  name           String
  keyHash        String       @unique
  keyPrefix      String
  status         APIKeyStatus @default(ACTIVE)
  quotaRemaining BigInt?
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("APIKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  usageLogs      UsageLog[]

  @@index([userId])
  @@index([createdById])
  @@index([status])
  @@index([keyPrefix])
}

model SetupState {
  id            String    @id @default(cuid())
  isInitialized Boolean   @default(false)
  initializedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SystemOption {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Channel {
  id              String        @id @default(cuid())
  name            String
  provider        String
  baseUrl         String?
  model           String?
  encryptedKey    String
  status          ChannelStatus @default(ACTIVE)
  priority        Int           @default(0)
  weight          Int           @default(1)
  rateLimitPerMin Int?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  usageLogs       UsageLog[]

  @@index([provider])
  @@index([status])
  @@index([priority, weight])
}

model UsageLog {
  id                 String   @id @default(cuid())
  userId             String
  apiKeyId           String?
  channelId          String?
  requestId          String?  @unique
  provider           String
  model              String?
  endpoint           String
  promptTokens       Int      @default(0)
  completionTokens   Int      @default(0)
  totalTokens        Int      @default(0)
  estimatedCostCents Int?
  statusCode         Int?
  success            Boolean  @default(true)
  errorCode          String?
  errorMessage       String?
  latencyMs          Int?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey             APIKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  channel            Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([channelId, createdAt])
  @@index([provider, model])
  @@index([success, createdAt])
}
