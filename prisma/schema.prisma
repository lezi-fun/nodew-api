generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum APIKeyStatus {
  ACTIVE
  REVOKED
}

enum ChannelStatus {
  ACTIVE
  DISABLED
}

enum RedemptionStatus {
  ACTIVE
  REDEEMED
  REVOKED
}

model User {
  id                          String       @id @default(cuid())
  email                       String       @unique
  username                    String       @unique
  passwordHash                String
  displayName                 String?
  emailVerifiedAt             DateTime?
  emailVerificationTokenHash   String?      @unique
  emailVerificationTokenExpiresAt DateTime?
  emailVerificationRequestedAt DateTime?
  pendingEmail                String?       @unique
  pendingEmailVerificationTokenHash String? @unique
  pendingEmailVerificationCodeHash  String?
  pendingEmailVerificationExpiresAt DateTime?
  pendingEmailVerificationRequestedAt DateTime?
  passwordResetTokenHash      String?
  passwordResetTokenExpiresAt DateTime?
  passwordResetRequestedAt    DateTime?
  accessToken                 String?      @unique
  settings                    Json?
  role                        UserRole     @default(USER)
  status                      UserStatus   @default(ACTIVE)
  groupId                     String?
  quotaRemaining              BigInt       @default(0)
  quotaUsed                   BigInt       @default(0)
  lastLoginAt                 DateTime?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
  group                       Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  apiKeys                     APIKey[]
  usageLogs                   UsageLog[]
  twoFA                       TwoFA?
  twoFABackupCodes            TwoFABackupCode[]
  passkeyCredential           PasskeyCredential?
  oauthBindings               UserOAuthBinding[]
  createdApiKeys              APIKey[]     @relation("APIKeyCreator")
  createdRedemptions          Redemption[] @relation("RedemptionCreator")
  redeemedRedemptions         Redemption[] @relation("RedeemedByUser")
  checkinRecords              UserCheckinRecord[]

  @@index([role])
  @@index([status])
  @@index([groupId])
}

model PendingUserRegistration {
  id                         String   @id @default(cuid())
  email                      String   @unique
  username                   String
  passwordHash               String
  displayName                String?
  verificationTokenHash      String   @unique
  verificationCodeHash       String
  verificationExpiresAt      DateTime
  verificationRequestedAt    DateTime
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([username])
  @@index([verificationExpiresAt])
}

model UserCheckinRecord {
  id          String   @id @default(cuid())
  userId      String
  checkinDate String
  rewardQuota BigInt   @default(100)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkinDate])
  @@index([checkinDate])
  @@index([userId, createdAt])
}

model TwoFA {
  id             String   @id @default(cuid())
  userId         String   @unique
  secret         String
  isEnabled      Boolean  @default(false)
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isEnabled])
  @@index([lockedUntil])
  @@index([deletedAt])
}

model TwoFABackupCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())
  deletedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isUsed])
  @@index([deletedAt])
}

model PasskeyCredential {
  id             String   @id @default(cuid())
  userId         String   @unique
  credentialId   String   @unique @db.VarChar(512)
  publicKey      String   @db.Text
  attestationType String   @db.VarChar(255)
  aaguid         String   @db.VarChar(512)
  signCount      Int      @default(0)
  cloneWarning   Boolean  @default(false)
  userPresent    Boolean  @default(false)
  userVerified    Boolean  @default(false)
  backupEligible Boolean  @default(false)
  backupState    Boolean  @default(false)
  transports     String   @db.Text
  attachment     String   @db.VarChar(32)
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
}

model UserOAuthBinding {
  id              String   @id @default(cuid())
  userId          String
  provider        String   @db.VarChar(64)
  providerUserId  String   @db.VarChar(191)
  email           String?  @db.VarChar(255)
  displayName     String?  @db.VarChar(255)
  avatarUrl       String?  @db.Text
  accessToken     String?  @db.Text
  refreshToken    String?  @db.Text
  scope           String?  @db.Text
  tokenType       String?  @db.VarChar(64)
  expiresAt       DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
  @@index([deletedAt])
}

model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Redemption {
  id               String           @id @default(cuid())
  codeHash         String           @unique
  codePrefix       String
  quotaAmount      BigInt
  status           RedemptionStatus @default(ACTIVE)
  expiresAt        DateTime?
  redeemedByUserId String?
  redeemedAt       DateTime?
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  redeemedByUser   User?            @relation("RedeemedByUser", fields: [redeemedByUserId], references: [id], onDelete: SetNull)
  createdBy        User             @relation("RedemptionCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdById])
  @@index([redeemedByUserId])
}

model APIKey {
  id             String       @id @default(cuid())
  userId         String
  createdById    String?
  name           String
  keyHash        String       @unique
  keyPrefix      String
  status         APIKeyStatus @default(ACTIVE)
  quotaRemaining BigInt?
  metadata       Json?
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("APIKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  usageLogs      UsageLog[]

  @@index([userId])
  @@index([createdById])
  @@index([status])
  @@index([keyPrefix])
}

model SetupState {
  id            String    @id @default(cuid())
  isInitialized Boolean   @default(false)
  initializedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SystemOption {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Channel {
  id              String        @id @default(cuid())
  name            String
  provider        String
  baseUrl         String?
  model           String?
  encryptedKey    String
  status          ChannelStatus @default(ACTIVE)
  priority        Int           @default(0)
  weight          Int           @default(1)
  rateLimitPerMin Int?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  usageLogs       UsageLog[]

  @@index([provider])
  @@index([status])
  @@index([priority, weight])
}

model RelaySelectionState {
  key       String   @id
  cursor    Int      @default(0)
  updatedAt DateTime @updatedAt
}

model UsageLog {
  id                 String   @id @default(cuid())
  userId             String
  apiKeyId           String?
  channelId          String?
  requestId          String?  @unique
  provider           String
  model              String?
  endpoint           String
  promptTokens       Int      @default(0)
  completionTokens   Int      @default(0)
  totalTokens        Int      @default(0)
  estimatedCostCents Int?
  statusCode         Int?
  success            Boolean  @default(true)
  errorCode          String?
  errorMessage       String?
  latencyMs          Int?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey             APIKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  channel            Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([channelId, createdAt])
  @@index([provider, model])
  @@index([success, createdAt])
}
