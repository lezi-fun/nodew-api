NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
# PostgreSQL is the default development database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nodew_api?schema=public"

# MySQL is also supported when the MySQL Prisma schema is generated first.
# DATABASE_URL="mysql://nodew_api:nodew_api@localhost:3306/nodew_api"
SESSION_SECRET="nodew-dev-session-secret"
CHANNEL_SECRET="nodew-dev-channel-secret"
