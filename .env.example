NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
# PostgreSQL is the default development database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nodew_api?schema=public"

# MySQL is also supported when the MySQL Prisma schema is generated first.
# DATABASE_URL="mysql://nodew_api:nodew_api@localhost:3306/nodew_api"
SESSION_SECRET="nodew-dev-session-secret"
CHANNEL_SECRET="nodew-dev-channel-secret"

# Optional third-party login. Configure only the providers you want to enable.
# APP_BASE_URL="http://127.0.0.1:3000"
# GITHUB_OAUTH_CLIENT_ID="Iv1.xxxxx"
# GITHUB_OAUTH_CLIENT_SECRET="github-oauth-secret"
# DISCORD_OAUTH_CLIENT_ID="discord-client-id"
# DISCORD_OAUTH_CLIENT_SECRET="discord-client-secret"
# LINUXDO_OAUTH_CLIENT_ID="linuxdo-client-id"
# LINUXDO_OAUTH_CLIENT_SECRET="linuxdo-client-secret"
# OIDC_OAUTH_ENABLED=true
# OIDC_OAUTH_WELL_KNOWN_URL="https://id.example.com/.well-known/openid-configuration"
# OIDC_OAUTH_CLIENT_ID="oidc-client-id"
# OIDC_OAUTH_CLIENT_SECRET="oidc-client-secret"
# OIDC_OAUTH_AUTHORIZATION_URL="https://id.example.com/oauth2/authorize"
# OIDC_OAUTH_TOKEN_URL="https://id.example.com/oauth2/token"
# OIDC_OAUTH_USERINFO_URL="https://id.example.com/oauth2/userinfo"
# OIDC_OAUTH_SCOPE="openid profile email"

# Optional Stripe wallet top-up. Webhook endpoint: /api/user/topup/stripe/webhook
# APP_BASE_URL="http://127.0.0.1:3000"
# STRIPE_TOPUP_ENABLED=false
# STRIPE_SECRET_KEY="sk_test_xxx"
# STRIPE_WEBHOOK_SECRET="whsec_xxx"
# STRIPE_CURRENCY="usd"
# STRIPE_QUOTA_PER_UNIT=100000
# STRIPE_UNIT_AMOUNT_CENTS=100
# STRIPE_MIN_UNITS=1

# Optional Creem wallet top-up. Webhook endpoint: /api/user/topup/creem/webhook
# APP_BASE_URL="http://127.0.0.1:3000"
# CREEM_TOPUP_ENABLED=false
# CREEM_API_KEY="creem_xxx"
# CREEM_WEBHOOK_SECRET="creem_whsec_xxx"
# CREEM_TEST_MODE=false
# CREEM_PRODUCTS='[{"productId":"prod_xxx","name":"100k quota","quotaAmount":100000,"amountCents":1000,"currency":"usd"}]'

# Optional object storage for persistent generated files and task assets.
# S3-compatible endpoints can be AWS S3, Cloudflare R2, MinIO, Tencent COS S3, etc.
STORAGE_DRIVER=disabled
# STORAGE_DRIVER=s3
# STORAGE_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
# STORAGE_REGION="auto"
# STORAGE_BUCKET="nodew-api"
# STORAGE_ACCESS_KEY_ID="replace-with-access-key"
# STORAGE_SECRET_ACCESS_KEY="replace-with-secret-key"
# STORAGE_PUBLIC_BASE_URL="https://assets.example.com/"
# STORAGE_FORCE_PATH_STYLE=false
# All stored objects are forced under the nodew/ directory.
STORAGE_PREFIX="nodew"
