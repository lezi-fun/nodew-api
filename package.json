{
  "name": "nodew-api",
  "version": "0.1.0",
  "private": true,
  "description": "Independent Node.js and TypeScript LLM gateway.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "build:web": "bun run --cwd web build",
    "build:server": "tsc -p tsconfig.json",
    "vercel-build": "bun run prisma:generate && bun run build:server && bun run build:web",
    "start": "node --env-file=.env dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev:postgres": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy:postgres": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:generate:mysql": "prisma generate --schema prisma/mysql/schema.prisma",
    "prisma:migrate:dev:mysql": "prisma migrate dev --schema prisma/mysql/schema.prisma",
    "prisma:migrate:deploy:mysql": "prisma migrate deploy --schema prisma/mysql/schema.prisma",
    "prisma:db:push:mysql": "prisma db push --schema prisma/mysql/schema.prisma",
    "prisma:studio:mysql": "prisma studio --schema prisma/mysql/schema.prisma",
    "prisma:studio": "prisma studio",
    "test": "vitest run -c vitest.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.1.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.7.0",
    "bullmq": "^5.49.1",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prisma": "^6.7.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
