{
  "name": "nodew-api",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js rewrite of a one-api style multi-provider gateway.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.7.0",
    "bullmq": "^5.49.1",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prisma": "^6.7.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
